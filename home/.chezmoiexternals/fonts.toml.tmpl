{{- if and (eq .chezmoi.os "linux") (not .isEphemeral) -}}
[".local/share/fonts/iMWriting"]
    type = "archive"
    url = {{ gitHubLatestReleaseAssetURL "ryanoasis/nerd-fonts" "iA-Writer.zip" | quote }}
    exact = true
    include = ["iMWritingMonoNerdFontMono-*.ttf"]
    refreshPeriod = "720h"

[".local/share/fonts/MapleMono"]
    type = "archive"
    url = {{ gitHubLatestReleaseAssetURL "subframe7536/maple-font" "MapleMono-CN-unhinted.zip" | quote }}
    exact = true
    include = ["MapleMono-CN*.ttf"]
    refreshPeriod = "720h"

[".local/share/fonts/SymbolsNerdFont"]
    type = "archive"
    url = {{ gitHubLatestReleaseAssetURL "ryanoasis/nerd-fonts" "NerdFontsSymbolsOnly.zip" | quote }}
    exact = true
    include = ["*.ttf"]
    refreshPeriod = "720h"

[".local/share/fonts/MaterialSymbolsRounded/MaterialSymbolsRounded.ttf"]
    type = "file"
    url = "https://github.com/google/material-design-icons/raw/master/variablefont/MaterialSymbolsRounded%5BFILL%2CGRAD%2Copsz%2Cwght%5D.ttf"
    refreshPeriod = "720h"
{{- end }}
